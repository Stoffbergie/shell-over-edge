{
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "name": "soe",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 8787",
    "build": "pnpm run typecheck",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm run check && wrangler deploy",
    "check": "pnpm run typecheck && pnpm run typecheck:test && pnpm run test && pnpm run repo:audit",
    "validate": "pnpm run check && pnpm run dry-run",
    "dry-run": "wrangler deploy --dry-run",
    "repo:audit": "node scripts/repo-audit.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test:load": "vitest run tests/e2e/relay-load.test.ts tests/e2e/agent-script.test.ts tests/e2e/direct-upgrade.test.ts",
    "native:build": "zig build --release=small",
    "test:native": "pnpm run native:build && vitest run tests/e2e/native-agent.test.ts",
    "test:containers": "pnpm run native:build:linux && SOE_DOCKER_E2E=1 vitest run tests/e2e/linux-container-agent.test.ts tests/e2e/native-linux-container-agent.test.ts",
    "native:build:linux": "node scripts/build-native-linux.mjs",
    "benchmark": "node scripts/benchmark.mjs"
  },
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "hono": "^4.12.24"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "homepage": "https://soe.stoff.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stoffberg/shell-over-edge.git"
  },
  "bugs": {
    "url": "https://github.com/Stoffberg/shell-over-edge/issues"
  },
  "license": "MIT",
  "description": "Reach any shell from anywhere."
}
